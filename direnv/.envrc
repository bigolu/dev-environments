main_worktree="$PWD/worktrees/main"
use_flake "$main_worktree"#
ln -sf ../../../../exclude "$main_worktree/.git/info/exclude"

for worktree in "$PWD/worktrees/"*; do
  if [[ ! -d $worktree ]]; then
    continue
  fi

  mkdir -p "$worktree/.vscode"
  ln -sf ../../../settings.json "$worktree/.vscode/settings.json"
  ln -nsf ../.. "$worktree/dev-env"
done

